name: VM Bootstrap / Deploy / Logs (Bittbridge)

on:
  workflow_dispatch:
    inputs:
      action:
        description: "bootstrap=install & create services, deploy=upload miner_model + restart, logs=show recent logs"
        required: true
        type: choice
        options: [bootstrap, deploy, logs]
      branch:
        description: "Branch to use on the VM (bootstrap only)"
        required: true
        default: "baseminerMA_customscikit"
      log_lines:
        description: "How many log lines to show (logs action only)"
        required: true
        default: "200"
      ssh_debug:
        description: "Enable verbose SSH debug output (prints lots of connection details)"
        required: false
        default: "false"

jobs:
  run:
    runs-on: ubuntu-latest

    steps:
      # Only needed for deploy (so we have miner_model/ locally)
      - name: Checkout (deploy only)
        if: ${{ inputs.action == 'deploy' }}
        uses: actions/checkout@v4

      - name: Configure SSH (write key safely + known_hosts)
        shell: bash
        run: |
          set -euo pipefail
          mkdir -p ~/.ssh
          chmod 700 ~/.ssh

          # Write the private key EXACTLY (avoid heredoc indentation corrupting the key)
          printf '%s' "${{ secrets.VM_SSH_KEY }}" > ~/.ssh/id_rsa
          # Normalize potential CRLF
          sed -i 's/\r$//' ~/.ssh/id_rsa
          chmod 600 ~/.ssh/id_rsa

          # Sanity-check the key parses
          ssh-keygen -lf ~/.ssh/id_rsa >/dev/null

          # Pin host key (consider replacing keyscan with a pre-pinned known_hosts secret for best security)
          ssh-keyscan -H "${{ secrets.VM_HOST }}" >> ~/.ssh/known_hosts
          chmod 600 ~/.ssh/known_hosts

      - name: SSH debug (optional)
        if: ${{ inputs.ssh_debug == 'true' }}
        shell: bash
        run: |
          set -euo pipefail
          ssh -vvv -i ~/.ssh/id_rsa -o StrictHostKeyChecking=yes \
            "${{ secrets.VM_USER }}@${{ secrets.VM_HOST }}" "echo ok"

      - name: Bootstrap VM (/opt, venv, deps, systemd, env keys)
        if: ${{ inputs.action == 'bootstrap' }}
        shell: bash
        env:
          REPO_SLUG: ${{ github.repository }}
          BRANCH: ${{ inputs.branch }}
          REPO_DIR: /opt/bittbridge/Bittbridge
          COINGECKO_API_KEY: ${{ secrets.COINGECKO_API_KEY }}
          WANDB_API_KEY: ${{ secrets.WANDB_API_KEY }}
          MINER_WALLET_NAME: ${{ secrets.MINER_WALLET_NAME }}
          MINER_HOTKEY_NAME: ${{ secrets.MINER_HOTKEY_NAME }}
          VALIDATOR_WALLET_NAME: ${{ secrets.VALIDATOR_WALLET_NAME }}
          VALIDATOR_HOTKEY_NAME: ${{ secrets.VALIDATOR_HOTKEY_NAME }}
        run: |
          set -euo pipefail

          # Create bootstrap script locally, then stream it to remote via stdin (simpler than base64 + quoting)
          cat > /tmp/bittbridge-bootstrap.sh <<'SCRIPT'
          set -euo pipefail

          sudo -n true

          sudo apt-get update
          sudo apt-get install -y git python3 python3-venv python3-pip rsync

          sudo mkdir -p /opt/bittbridge
          # Use the SSH user (SUDO_USER) when available; fallback to current user
          OWNER_USER="${SUDO_USER:-$USER}"
          sudo chown -R "$OWNER_USER:$OWNER_USER" /opt/bittbridge

          if [ ! -d "$REPO_DIR/.git" ]; then
            git clone --branch "$BRANCH" "https://github.com/$REPO_SLUG.git" "$REPO_DIR"
          fi

          cd "$REPO_DIR"
          git fetch origin

          # Be robust even if branch isn't currently checked out locally
          git checkout -B "$BRANCH" "origin/$BRANCH"
          git pull --ff-only

          if [ ! -d venv ]; then
            python3 -m venv venv
          fi

          ./venv/bin/python -m pip install --upgrade pip setuptools wheel
          ./venv/bin/pip install bittensor bittensor-cli wandb pytz

          # Write env file with current values
          sudo mkdir -p /etc/bittbridge
          sudo python3 - <<'PY'
          from pathlib import Path
          import os

          env_txt = """SUBTENSOR_NETWORK=test
](#)
